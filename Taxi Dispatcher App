  .vc2 { background: #22c55e; top: 60%; left: 60%; box-shadow: 0 0 12px #22c55e; animation: float2 7s ease-in-out infinite; }
  .vc3 { background: #60a5fa; top: 40%; left: 80%; box-shadow: 0 0 12px #60a5fa; animation: float1 5s ease-in-out infinite 1s; }
  @keyframes float1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(20px,-15px); } }
  @keyframes float2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-15px,20px); } }

  /* ===== GIF ANIMATION STRIP ===== */
  .anim-strip {
    background: var(--dark); padding: 1rem 5vw;
    display: flex; align-items: center; gap: 2rem; overflow: hidden; white-space: nowrap;

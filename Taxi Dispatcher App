  .anim-item { color: rgba(255,255,255,.5); font-size: .85rem; display: flex; align-items: center; gap: .5rem; flex-shrink: 0; }
  .anim-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; animation: blink 2s infinite; }
  .green-dot { background: #22c55e; }
  .yellow-dot { background: var(--yellow); animation-delay: .5s; }
  .blue-dot { background: #60a5fa; animation-delay: 1s; }
  @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:.3; } }

  /* responsive */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding-bottom: 0; }
    .hero-visual { display: none; }
    .stats-strip, .feature-grid, .ai-grid { grid-template-columns: 1fr 1fr; }
    .pain-cols, .how-grid, .benefits-grid, .faq-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .stats-strip, .feature-grid, .ai-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: 2fr 2fr; }
  }
</style>
